# Local Docker Compose runtime selection.
# Copy to .env for local container runs:
#   cp .env.compose.example .env

# Runtime backend:
#   external - RabbitMQ + Redis path
#   postgres - PostgreSQL runtime queue/session path
RUNTIME_BACKEND=external

# Shared local PostgreSQL URL used by proxy in postgres mode.
DATABASE_URL=postgresql://cognitor:changeme@postgres:5432/cognitor
