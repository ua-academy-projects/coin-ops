# Приклад змінних середовища для CoinOps. Оригінальні файли:
#   Frontend:        ./services/frontend/frontend.env
#   Proxy:           ./services/proxy/proxy.env
#   History worker:  ./services/worker/worker.env
#   Database (init): ./services/database/database.env

# --- Frontend (services/frontend/frontend.env) ---
PROXY_URL="http://your_proxy_host:8080"
# База History Service або повний шлях (legacy):
# HISTORY_BASE_URL="http://your_history_host:8090"
HISTORY_API_URL="http://your_history_host:8090/api/v1/history"
# Опційно: Redis для UI state (якщо не задано — лише localStorage)
# REDIS_URL="redis://127.0.0.1:6379/0"
# COINOPS_RATES_PATH="/api/v1/rates"
# COINOPS_HTTP_TIMEOUT="15"
# COINOPS_REDIS_KEY_PREFIX="coinops:ui:"
# COINOPS_UI_STATE_TTL_SECONDS="31536000"

# --- Proxy (services/proxy/proxy.env) ---
COINOPS_LISTEN=":8080"
MQ_ENABLED="TRUE"
RABBITMQ_URL="amqp://user:password@your_rabbitmq_host:5672/"
RABBITMQ_EXCHANGE="coinops.rates"
RABBITMQ_ROUTING_KEY="rates.snapshot"
# Опційно:
# COINOPS_CACHE_TTL_SECONDS="60"
# COINOPS_POLL_ENABLED="true"
# COINOPS_POLL_INTERVAL_SECONDS="600"
# COINOPS_CORS_ALLOW_ORIGIN=""

# --- History service / worker (services/worker/worker.env) ---
PGHOST="your_database_host"
PGPORT="5432"
PGUSER="your_database_user"
PGPASSWORD="your_database_password"
PGDATABASE="your_database_name"
# Або одним рядком: DATABASE_URL="postgresql://user:pass@host:5432/dbname"
RABBITMQ_URL="amqp://user:password@your_rabbitmq_host:5672/"
RABBITMQ_EXCHANGE="coinops.rates"
RABBITMQ_QUEUE="coinops.history"
RABBITMQ_ROUTING_KEY="rates.snapshot"
MQ_CONSUMER_ENABLED="true"
HTTP_API_ENABLED="true"
HISTORY_LISTEN="0.0.0.0"
HISTORY_PORT="8090"
# Опційно:
# MQ_PREFETCH_COUNT="10"
# MQ_RECONNECT_BACKOFF_INITIAL="1.0"
# MQ_RECONNECT_BACKOFF_MAX="60.0"
# HISTORY_CORS_ALLOW_ORIGIN=""

# --- PostgreSQL init (services/database/database.env) ---
PGUSER="your_database_user"
PGPASSWORD="your_database_password"
PGDATABASE="your_database_name"
