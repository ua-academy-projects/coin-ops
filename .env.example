# Copy to .env and fill in real values:
#   cp .env.example .env
#
# Then load before running Terraform or Ansible:
#   source .env

# ── SSH key (shared: Terraform injects it, Ansible uses it) ───
export SSH_KEY_PATH=terraform/keys/softserve_rsa
# generate with: ssh-keygen -t ed25519 -f terraform/keys/softserve_rsa -N ""

# ── Terraform ─────────────────────────────────────────────────
export TF_VAR_winrm_user=Administrator
export TF_VAR_winrm_password=YourWindowsPassword

# Windows host IP reachable from WSL:
#   ip route show default | awk '{print $3}'
export TF_VAR_winrm_host=172.20.0.1

# Windows paths to your Hyper-V storage
export TF_VAR_base_vhd_path='C:\HyperV\images\ubuntu-24.04-cloud.vhd'
export TF_VAR_vm_storage_path='C:\HyperV\vms'
export TF_VAR_seed_staging_windows_path='C:\HyperV\seed'
export TF_VAR_seed_staging_wsl_path=/mnt/c/HyperV/seed

# Derived from SSH_KEY_PATH — no need to set manually
export TF_VAR_ssh_public_key=$(cat "${SSH_KEY_PATH}.pub" 2>/dev/null || echo "run: ssh-keygen -t ed25519 -f ${SSH_KEY_PATH} -N ''")

# ── Ansible ───────────────────────────────────────────────────
export RABBITMQ_PASSWORD=changeme
export DB_PASSWORD=changeme
