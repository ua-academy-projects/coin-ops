# Copy to .env and fill in real values:
#   cp .env.example .env
#
# Load before running Terraform or Ansible (from WSL, inside the repo root):
#   source .env
#
# NOTE: All paths below must be ABSOLUTE LINUX paths (WSL-style).
# Example for a key stored on the D: drive: /mnt/d/path/to/key

# ── SSH key (shared: Terraform injects it, Ansible uses it) ───────────────────
# Generate once (run from WSL):
#   ssh-keygen -t ed25519 -f ~/.ssh/coin-ops-key -N ""
export SSH_KEY_PATH=~/.ssh/coin-ops-key

# SSH connection vars — Ansible reads these directly (no file lookup needed).
# Must match config.json general.username and general.ssh_port.
export SSH_USER="coinops"
export SSH_PORT="53725"

# Derived — do not edit manually; reads SSH_KEY_PATH.pub automatically
export TF_VAR_ssh_public_key_path="${SSH_KEY_PATH}.pub"

# ── Terraform: Cloud Credentials ─────────────────────────────────────────────
export TF_VAR_gcp_project_id=your-gcp-project-id
# Absolute path to the GCP service-account JSON key (never commit this file):
export GOOGLE_APPLICATION_CREDENTIALS=$(pwd)/terraform/sa-key.json
export AWS_ACCESS_KEY_ID=your_aws_access_key_id
export AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
export TF_VAR_aws_region=eu-north-1
export TF_VAR_gcp_region=europe-central2

# ── Ansible: Cloud-Native Inventory (google.cloud.gcp_compute / amazon.aws.aws_ec2) ──
# These mirror the Terraform vars so you only set values in one place:
export GOOGLE_CLOUD_PROJECT=$TF_VAR_gcp_project_id
export GCP_PROJECT=$TF_VAR_gcp_project_id
export GCP_SERVICE_ACCOUNT_FILE=$GOOGLE_APPLICATION_CREDENTIALS
export GCP_REGION=$TF_VAR_gcp_region
export AWS_REGION=$TF_VAR_aws_region

# Tells Ansible where to find ansible.cfg (lives in the repo root; run `source .env` from there):
export ANSIBLE_CONFIG=$(pwd)/ansible.cfg

# ── Ansible: Application Secrets ─────────────────────────────────────────────
export DB_PASSWORD=changeme_strong_password
export RABBITMQ_PASSWORD=changeme_strong_password

# ── Ansible: Runtime Backend ──────────────────────────────────────────────────
# external — Redis + RabbitMQ as Docker containers (default, recommended for first deploy)
# postgres — queue/session via PostgreSQL pgmq extension
export RUNTIME_BACKEND=external

# ── Ansible: Public UI Entrypoint ─────────────────────────────────────────────
# Set this to the public IP of app-1 OR a real domain once DNS is configured.
# For first deploy with no domain yet, use the raw public IP:
#   export APP_DOMAIN=34.116.186.231
export APP_DOMAIN=coinops.yourdomain.com

# TLS modes:
#   selfsigned — Ansible generates /etc/cognitor/tls/coinops.{crt,key} on app-1
#   provided   — cert/key must already exist on app-1 (for Let's Encrypt / Cloudflare)
#   off        — HTTP only; safe for first-deploy testing
export TLS_MODE=selfsigned

# ── Ansible: Container Images (GHCR) ─────────────────────────────────────────
# Required when GHCR packages are private (they are by default).
# Create a GitHub classic PAT with read:packages scope, then fill in:
export GHCR_USERNAME=your-github-username
export GHCR_TOKEN=github_pat_your_token_here

# Pin to a specific image tag for immutable deploys (default: moving branch tag).
# export IMAGE_TAG=v0.1.0
