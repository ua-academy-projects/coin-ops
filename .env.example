# Copy to .env and fill in real values.
#   cp .env.example .env
#
# Load before running Ansible:
#   source .env
#   ansible-playbook -i ansible/inventory ansible/provision.yml

# ── Ansible: service passwords ────────────────────────────────
# Used by provision.yml to create DB/RabbitMQ users.
RABBITMQ_PASSWORD=changeme
DB_PASSWORD=changeme

# ── Ansible: SSH key path ─────────────────────────────────────
# Private key injected into VMs via cloud-init / Terraform.
# WSL example: /mnt/f/univ/softserv-internship/terraform/keys/softserve_rsa
SSH_KEY_PATH=~/.ssh/softserve_key

# ── Runtime service env (used by proxy + history systemd units) ──
# These are written to /etc/cognitor/*.env by Ansible, but handy
# to have here for local dev / manual testing.
RABBITMQ_URL=amqp://cognitor:changeme@172.31.1.10:5672/
DATABASE_URL=postgresql://cognitor:changeme@172.31.1.10:5432/cognitor
PORT=8080
