# Azure
export SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
export AZURE_AUTH_LOCATION=/Users/username/.secrets/azure/sp-key.json
export AZURE_IDENTITY_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
export AZURE_IDENTITY_ID=/subscriptions/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# AWS
export AWS_ACCESS_KEY_ID=
export AWS_SECRET_ACCESS_KEY=
export AWS_DEFAULT_REGION=eu-central-1

# Cloudflare
export TF_VAR_cloudflare_api_token=your_cloudflare_token_here
export TF_VAR_cloudflare_zone_id=your_cloudflare_zone_id_here

# Terraform variables
export TF_VAR_db_name=currency_rates_tracker
export TF_VAR_db_user=currency_app_user
export TF_VAR_db_password=yourpassword
export TF_VAR_domain_name=coin-ops.pp.ua

# RDS
export RDS_ENDPOINT=yourdb.xxxxxxxxxxxx.eu-central-1.rds.amazonaws.com

# App
export POSTGRES_USER=currency_app_user
export POSTGRES_DB=currency_rates_tracker
export POSTGRES_TABLE=currency_rates
export POSTGRES_PASS=yourpassword
export RABBITMQ_USER=currency_app_user
export RABBITMQ_PASS=yourpassword
export RABBITMQ_QUEUE=currency_rates
export REDIS_PASSWORD=yourpassword
export SECRET_KEY=yoursecretkey

# SSH
export SSH_KEY_PATH=~/.ssh/id_ed25519