# Copy to .env and fill in real values:
#   cp .env.example .env
#
# Then load before running Terraform or Ansible:
#   source .env

# ── SSH key (shared: Terraform injects it, Ansible uses it) ───
# Must be an ABSOLUTE path — Ansible does not resolve relative paths correctly.
# Generate once: ssh-keygen -t ed25519 -f ~/.ssh/coinops_gcp -N ""
export SSH_KEY_PATH=/Users/your-user/.ssh/coinops_gcp

# Derived — shared with Terraform cloud config
export TF_VAR_ssh_public_key_path="${SSH_KEY_PATH}.pub"

# Emergency console password — used when SSH key auth is unavailable
# (Hyper-V console login only, not exposed over network)
export TF_VAR_vm_console_password=changeme

# ── Terraform: WinRM (Hyper-V host connection) ────────────────
export TF_VAR_winrm_user=Administrator
export TF_VAR_winrm_password=YourWindowsPassword

# Windows host IP reachable from WSL:
#   ip route show default | awk '{print $3}'
export TF_VAR_winrm_host=172.20.0.1

# ── Terraform: Hyper-V storage paths ─────────────────────────
# All on F: drive under the project folder — no C: disk usage.
# WSL path:     /mnt/f/univ/softserv-internship/hyper-v/<subdir>
# Windows path: F:\univ\softserv-internship\hyper-v\<subdir>
#
# base_vhd_path — converted Ubuntu 24.04 VHDX (see README for conversion steps)
export TF_VAR_base_vhd_path='F:\univ\softserv-internship\hyper-v\images\ubuntu-24.04-cloud.vhdx'
export TF_VAR_vm_storage_path='F:\univ\softserv-internship\hyper-v\vms'
export TF_VAR_seed_staging_windows_path='F:\univ\softserv-internship\hyper-v\seed'
export TF_VAR_seed_staging_wsl_path=/mnt/f/univ/softserv-internship/hyper-v/seed

# Public UI entrypoint. For local lab HTTPS, add this hosts entry on your machine:
#   172.31.1.12 coinops.test
export APP_DOMAIN=coinops.test

# TLS modes:
#   selfsigned - Ansible generates /etc/cognitor/tls/coinops.{crt,key} on node-03
#   provided   - you place those files on node-03 yourself
#   off        - HTTP-only fallback
export TLS_MODE=selfsigned

# Optional: deploy an immutable release tag instead of the moving branch tag.
# export IMAGE_TAG=v0.1.0

# Optional local overrides for non-GCP flows.
# GCP deploys fetch GHCR / app secrets from Google Secret Manager.
