[history]
vm-1 ansible_host=10.0.0.5 ansible_ssh_common_args='-o StrictHostKeyChecking=no -o ProxyCommand="ssh -o StrictHostKeyChecking=no -o IdentitiesOnly=yes -i ~/.ssh/gcp_jump -p 47832 -W %h:%p terraform@34.134.179.161"'

[proxy]
vm-2 ansible_host=10.0.0.2 ansible_ssh_common_args='-o StrictHostKeyChecking=no -o ProxyCommand="ssh -o StrictHostKeyChecking=no -o IdentitiesOnly=yes -i ~/.ssh/gcp_jump -p 47832 -W %h:%p terraform@34.134.179.161"'

[ui]
vm-3 ansible_host=10.0.0.4 ansible_ssh_common_args='-o StrictHostKeyChecking=no -o ProxyCommand="ssh -o StrictHostKeyChecking=no -o IdentitiesOnly=yes -i ~/.ssh/gcp_jump -p 47832 -W %h:%p terraform@34.134.179.161"'

[all:vars]
ansible_user=terraform
ansible_port=47832
ansible_ssh_private_key_file=~/.ssh/gcp_jump
ansible_python_interpreter=/usr/bin/python3.11
