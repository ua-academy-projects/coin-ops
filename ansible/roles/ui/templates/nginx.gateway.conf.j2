{% if tls_enabled | bool %}
server {
    listen 80;
    server_name {{ app_domain }};

    location = /health {
        access_log off;
        add_header Content-Type application/json;
        return 200 '{"status":"ok"}';
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    http2 on;
    server_name {{ app_domain }};

    ssl_certificate /etc/nginx/tls/coinops.crt;
    ssl_certificate_key /etc/nginx/tls/coinops.key;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

{% else %}
server {
    listen 80;
    server_name {{ app_domain }} _;

{% endif %}
    root /usr/share/nginx/html;
    index index.html;

    location = /health {
        access_log off;
        add_header Content-Type application/json;
        return 200 '{"status":"ok"}';
    }

    location /api/ {
        proxy_pass http://{{ hostvars[groups['proxy'][0]]['ansible_host'] | default('172.31.1.11') }}:{{ proxy_port }}/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /history-api/ {
        proxy_pass http://{{ hostvars[groups['history'][0]]['ansible_host'] | default('172.31.1.10') }}:{{ history_port }}/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        try_files $uri /index.html;
    }

    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    gzip on;
    gzip_types text/html text/css application/javascript application/json;
}
