# Copy to ansible/inventory and fill in real key paths for your machine.
# ansible/inventory is gitignored — never commit the real one.
#
# WSL key path pattern:
#   /mnt/<drive>/<path-to-project>/.vagrant/machines/<vm-name>/hyperv/private_key
#
# Find your VM names:
#   Windows:  ls .vagrant\machines\
#   WSL:      ls /mnt/f/univ/softserv-internship/.vagrant/machines/

[history]
softserve-node-01 ansible_host=172.31.1.10 ansible_ssh_private_key_file=/mnt/f/univ/softserv-internship/.vagrant/machines/node-1/hyperv/private_key

[proxy]
softserve-node-02 ansible_host=172.31.1.11 ansible_ssh_private_key_file=/mnt/f/univ/softserv-internship/.vagrant/machines/node-2/hyperv/private_key

[ui]
softserve-node-03 ansible_host=172.31.1.12 ansible_ssh_private_key_file=/mnt/f/univ/softserv-internship/.vagrant/machines/node-3/hyperv/private_key
