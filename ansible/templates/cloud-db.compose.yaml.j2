services:
  postgres:
    image: "{{ postgres_image }}"
    restart: unless-stopped
    env_file:
      - /etc/cognitor/cloud-db.env
{% if runtime_backend == "postgres" %}
    command:
      - postgres
      - -c
      - listen_addresses=*
      - -c
      - shared_preload_libraries=pg_cron
      - -c
      - cron.database_name={{ db_name }}
{% endif %}
    ports:
      - "{{ cloud_db_host }}:5432:5432"
    volumes:
      - /var/lib/coin-ops/postgres:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $$POSTGRES_USER -d $$POSTGRES_DB"]
      interval: 10s
      timeout: 5s
      retries: 5

{% if runtime_backend == "external" %}
  rabbitmq:
    image: rabbitmq:3-alpine
    restart: unless-stopped
    env_file:
      - /etc/cognitor/cloud-db.env
    ports:
      - "{{ cloud_db_host }}:5672:5672"
    volumes:
      - /var/lib/coin-ops/rabbitmq:/var/lib/rabbitmq
    healthcheck:
      test: rabbitmq-diagnostics -q ping
      interval: 10s
      timeout: 5s
      retries: 5

  redis:
    image: redis:7-alpine
    restart: unless-stopped
    ports:
      - "{{ cloud_db_host }}:6379:6379"
    volumes:
      - /var/lib/coin-ops/redis:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
{% endif %}
