services:
  history-api:
    image: "{{ history_api_image }}"
    restart: unless-stopped
    env_file:
      - /etc/cognitor/cloud-app.env
    environment:
      PORT: "{{ history_port }}"

  history-consumer:
    image: "{{ history_consumer_image }}"
    restart: unless-stopped
    env_file:
      - /etc/cognitor/cloud-app.env

  proxy:
    image: "{{ proxy_image }}"
    restart: unless-stopped
    env_file:
      - /etc/cognitor/cloud-app.env
    environment:
      PORT: "{{ proxy_port }}"

  ui:
    image: "{{ ui_image }}"
    restart: unless-stopped
    ports:
      - "80:80"
    environment:
      PROXY_URL: /api
      HISTORY_URL: /history-api
    volumes:
      - /opt/cognitor/cloud-app/nginx.conf:/etc/nginx/conf.d/default.conf:ro
    depends_on:
      - proxy
      - history-api
