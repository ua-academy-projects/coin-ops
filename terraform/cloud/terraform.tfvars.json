{
  "network": {
    "name": "coinops-network",
    "cidr": "10.10.0.0/16",
    "subnets": {
      "app": {
        "cidr": "10.10.1.0/24",
        "placement": "primary",
        "exposure": "private"
      },
      "edge": {
        "cidr": "10.10.2.0/24",
        "placement": "primary",
        "exposure": "public"
      }
    }
  },
  "nat_route": {
    "name": "coinops-private-egress",
    "destination_range": "0.0.0.0/0",
    "instance_workload": "coinops-nat",
    "target_tags": ["private-egress"]
  },
  "workloads": {
    "coinops-history": {
      "instance_type": "micro",
      "image_family": "ubuntu_24",
      "placement": "primary",
      "subnet": "app",
      "tags": ["ssh", "history-api", "postgres", "private-egress"],
      "disk_size_gb": 20,
      "public_ip": false,
      "can_ip_forward": false
    },
    "coinops-proxy": {
      "instance_type": "micro",
      "image_family": "ubuntu_24",
      "placement": "primary",
      "subnet": "app",
      "tags": ["ssh", "proxy-api", "private-egress"],
      "disk_size_gb": 20,
      "public_ip": false,
      "can_ip_forward": false
    },
    "coinops-ui": {
      "instance_type": "micro",
      "image_family": "ubuntu_24",
      "placement": "primary",
      "subnet": "edge",
      "tags": ["ssh", "ui", "ui-http", "ui-https"],
      "disk_size_gb": 20,
      "public_ip": true,
      "can_ip_forward": false
    },
    "coinops-bastion": {
      "instance_type": "micro",
      "image_family": "ubuntu_24",
      "placement": "primary",
      "subnet": "edge",
      "tags": ["bastion"],
      "disk_size_gb": 10,
      "public_ip": true,
      "can_ip_forward": false
    },
    "coinops-nat": {
      "instance_type": "micro",
      "image_family": "ubuntu_24",
      "placement": "primary",
      "subnet": "edge",
      "tags": ["ssh", "nat"],
      "disk_size_gb": 10,
      "public_ip": true,
      "can_ip_forward": true
    }
  },
  "security_rules": {
    "ssh_bastion": {
      "description": "Allow SSH from my IP to bastion",
      "direction": "INGRESS",
      "priority": 1000,
      "protocol": "tcp",
      "ports": ["22"],
      "cidr_blocks": ["178.212.243.26/32"],
      "source_workloads": [],
      "target_workloads": ["coinops-bastion"]
    },
    "ssh_internal": {
      "description": "Allow SSH from bastion to internal instances",
      "direction": "INGRESS",
      "priority": 1000,
      "protocol": "tcp",
      "ports": ["22"],
      "cidr_blocks": [],
      "source_workloads": ["coinops-bastion"],
      "target_workloads": ["coinops-history", "coinops-proxy", "coinops-ui", "coinops-nat"]
    },
    "ui_http": {
      "description": "Allow HTTP to UI",
      "direction": "INGRESS",
      "priority": 1000,
      "protocol": "tcp",
      "ports": ["80"],
      "cidr_blocks": ["0.0.0.0/0"],
      "source_workloads": [],
      "target_workloads": ["coinops-ui"]
    },
    "ui_https": {
      "description": "Allow HTTPS to UI",
      "direction": "INGRESS",
      "priority": 1000,
      "protocol": "tcp",
      "ports": ["443"],
      "cidr_blocks": ["0.0.0.0/0"],
      "source_workloads": [],
      "target_workloads": ["coinops-ui"]
    },
    "proxy_api": {
      "description": "Allow UI to reach proxy API",
      "direction": "INGRESS",
      "priority": 1000,
      "protocol": "tcp",
      "ports": ["8080"],
      "cidr_blocks": [],
      "source_workloads": ["coinops-ui"],
      "target_workloads": ["coinops-proxy"]
    },
    "history_api": {
      "description": "Allow UI to reach history API",
      "direction": "INGRESS",
      "priority": 1000,
      "protocol": "tcp",
      "ports": ["8000"],
      "cidr_blocks": [],
      "source_workloads": ["coinops-ui"],
      "target_workloads": ["coinops-history"]
    },
    "nat_forward_tcp": {
      "description": "Allow private app nodes to forward TCP traffic through NAT",
      "direction": "INGRESS",
      "priority": 1000,
      "protocol": "tcp",
      "ports": [],
      "cidr_blocks": [],
      "source_workloads": ["coinops-history", "coinops-proxy"],
      "target_workloads": ["coinops-nat"]
    },
    "nat_forward_udp": {
      "description": "Allow private app nodes to forward UDP traffic through NAT",
      "direction": "INGRESS",
      "priority": 1000,
      "protocol": "udp",
      "ports": [],
      "cidr_blocks": [],
      "source_workloads": ["coinops-history", "coinops-proxy"],
      "target_workloads": ["coinops-nat"]
    },
    "nat_forward_icmp": {
      "description": "Allow private app nodes to forward ICMP traffic through NAT",
      "direction": "INGRESS",
      "priority": 1000,
      "protocol": "icmp",
      "ports": [],
      "cidr_blocks": [],
      "source_workloads": ["coinops-history", "coinops-proxy"],
      "target_workloads": ["coinops-nat"]
    },
    "postgres": {
      "description": "Allow app nodes to reach PostgreSQL",
      "direction": "INGRESS",
      "priority": 1000,
      "protocol": "tcp",
      "ports": ["5432"],
      "cidr_blocks": [],
      "source_workloads": ["coinops-history", "coinops-proxy"],
      "target_workloads": ["coinops-history"]
    }
  }
}
