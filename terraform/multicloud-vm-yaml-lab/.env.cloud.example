# Copy this file to the repo root .env or source it directly before cloud deploy:
#   cp terraform/multicloud-vm-yaml-lab/.env.cloud.example .env
#   source .env
#
# Do not commit real .env files or real tokens.

# SSH key used by Terraform-created VMs and Ansible.
# The matching public key path is configured in config/lab.yaml.
export SSH_KEY_PATH=~/.ssh/coinops_gcp_jump

# Required by ansible/cloud-deploy.yml.
# Pick strong values for real deploys.
export DB_PASSWORD=change-me-db-password
export RABBITMQ_PASSWORD=change-me-rabbitmq-password

# Runtime backend for the app containers.
# external = PostgreSQL + RabbitMQ + Redis services on the private DB VM.
# postgres = PostgreSQL runtime image path.
export RUNTIME_BACKEND=external

# Container image source.
export IMAGE_REGISTRY=ghcr.io/ua-academy-projects
export IMAGE_TAG=dev-latest

# Required if GHCR packages are private.
# GitHub classic PAT needs read:packages; private repo/org access may also need repo.
export GHCR_USERNAME=your-github-username
export GHCR_TOKEN=your-github-token-with-read-packages

# Required only when config/lab.yaml has domain.enabled: true and create_records: true.
# Cloudflare token permissions: Zone:Read and DNS:Edit for the zone.
export CLOUDFLARE_API_TOKEN=your-cloudflare-token

# Usually not needed because Terraform provider/backend uses profile from YAML/backend.hcl.
# Export only if you want AWS CLI commands to default to the lab profile.
export AWS_PROFILE=coinops-lab
export AWS_REGION=eu-central-1