# Copy this file to the repo root .env or source it before lab commands:
#   cp terraform/multicloud-vm-yaml-lab/examples/env.cloud.example .env
#   source .env
#
# Do not commit real .env files or real tokens.

# SSH key used by Ansible. The public key path is configured in config/lab.yaml.
export SSH_KEY_PATH=~/.ssh/coinops_gcp_jump

# Local input for ./scripts/lab.sh secrets push.
# In the current managed DB implementation this is still also exported as
# TF_VAR_db_password during Terraform runs, so do not commit it and prefer a
# temporary shell/.env value only.
export DB_PASSWORD=changeme

# Required only for external/postgres VM-runtime modes, not cloud-native.
export RABBITMQ_PASSWORD=changeme

# Runtime backend is configured in terraform/multicloud-vm-yaml-lab/config/lab.yaml:
#   runtime:
#     mode: cloud-native
# .env carries only local operator values and secret source values.

# Container image source.
export IMAGE_REGISTRY=ghcr.io/ua-academy-projects
export IMAGE_TAG=dev-latest

# Required if GHCR packages are private. GitHub classic PAT needs read:packages;
# pushing images also needs write:packages.
export GHCR_USERNAME=
export GHCR_TOKEN=

# Required only when config/lab.yaml has domain.enabled: true and create_records: true.
# Cloudflare token permissions: Zone:Read and DNS:Edit for the zone.
export CLOUDFLARE_API_TOKEN=

# AWS profile used by lab.sh for doctor/secrets push and by Terraform provider/backend.
export AWS_PROFILE=coinops-lab
export AWS_REGION=eu-central-1

# Optional GCP override for secret push/doctor if YAML does not define project_id.
export GCP_PROJECT_ID=