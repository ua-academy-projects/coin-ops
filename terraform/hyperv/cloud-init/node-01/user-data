#cloud-config
users:
  - name: vagrant
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    lock_passwd: false
    ssh_authorized_keys:
      - REPLACE_WITH_SSH_KEY

chpasswd:
  list: |
    vagrant:REPLACE_WITH_CONSOLE_PASSWORD
  expire: false

package_update: true
packages:
  - openssh-server
  - python3

runcmd:
  - systemctl enable ssh
  - systemctl start ssh
