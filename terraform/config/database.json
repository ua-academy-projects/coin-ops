{
    "database": {
        "enabled": true,
        "engine": "postgres",
        "version": "16",
        "name": "cognitor",
        "username": "cognitor",
        "port": 5432,
        "cloud_profiles": {
            "gcp": {
                "tier": "db-f1-micro",
