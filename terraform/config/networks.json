{
    "vpc_name": "coin-ops-vpc",
    "vpc_cidr": "10.10.0.0/16",
    "subnets": {
        "internal": { "cidr": "10.10.1.0/24" },
        "external": { "cidr": "10.10.2.0/24", "public": true }
    },
    "firewall_rules": {
        "allow-ssh-jump-host": {
            "protocols": [{ "protocol": "tcp", "ports": ["22"] }],
            "source_cidrs": ["0.0.0.0/0"],
            "target_role": "jump-host"
        },
        "allow-http-https-app": {
            "protocols": [{ "protocol": "tcp", "ports": ["80", "443"] }],
            "source_cidrs": ["0.0.0.0/0"],
            "target_role": "app"
        },
        "allow-app-from-jump": {
            "protocols": [{ "protocol": "tcp", "ports": ["22", "8080", "8000"] }],
            "source_role": "jump-host",
            "target_role": "app"
        },
        "allow-db-from-jump": {
            "protocols": [{ "protocol": "tcp", "ports": ["22", "5432"] }],
            "source_role": "jump-host",
            "target_role": "db"
        },
        "allow-db-from-app": {
            "protocols": [{ "protocol": "tcp", "ports": ["5432"] }],
            "source_role": "app",
            "target_role": "db"
        },
        "allow-history-api-from-app": {
            "protocols": [{ "protocol": "tcp", "ports": ["8000"] }],
            "source_role": "app",
            "target_role": "app"
        }
    }
}
