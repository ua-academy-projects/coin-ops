{
    "vpc_name": "coin-ops-vpc",
    "vpc_cidr": "10.10.0.0/16",
    "routing": {
        "private_default_route": {
            "destination_cidr": "0.0.0.0/0",
            "priority": 800,
            "target_tags": ["internal-vm"],
            "name": "coin-ops-private-default-via-jump"
        }
    },
    "security": {
        "egress_cidrs": ["0.0.0.0/0"]
    },
    "subnets": {
        "internal": { "cidr": "10.10.1.0/24" },
        "external": { "cidr": "10.10.2.0/24", "public": true }
    },
    "firewall_rules": {
        "allow-ssh-jump-host": {
            "protocols": [{ "protocol": "tcp", "ports": ["53725"] }],
            "source_cidrs": ["0.0.0.0/0"],
            "target_role": "jump-host"
        },
        "allow-nat-from-internal-to-jump": {
            "protocols": [
                { "protocol": "tcp", "ports": ["1-65535"] },
                { "protocol": "udp", "ports": ["1-65535"] },
                { "protocol": "icmp" }
            ],
            "source_cidrs": ["10.10.1.0/24"],
            "target_role": "jump-host"
        },
        "allow-http-https-app-ui": {
            "protocols": [{ "protocol": "tcp", "ports": ["443"] }],
            "source_cidrs": ["0.0.0.0/0"],
            "target_role": "app-ui"
        },
        "allow-app-ui-from-jump": {
            "protocols": [{ "protocol": "tcp", "ports": ["53725"] }],
            "source_role": "jump-host",
            "target_role": "app-ui"
        },
        "allow-app-backend-from-jump": {
            "protocols": [{ "protocol": "tcp", "ports": ["53725", "8080", "8000"] }],
            "source_role": "jump-host",
            "target_role": "app-backend"
        },
        "allow-backend-from-ui": {
            "protocols": [{ "protocol": "tcp", "ports": ["8000", "8080"] }],
            "source_role": "app-ui",
            "target_role": "app-backend"
        },
        "allow-all-internal": {
            "protocols": [
                { "protocol": "tcp", "ports": ["1-65535"] },
                { "protocol": "udp", "ports": ["1-65535"] },
                { "protocol": "icmp" }
            ],
            "source_cidrs": ["10.10.0.0/16"],
            "target_tags": ["app-ui", "app-backend", "jump-host"]
        }
    }
}
