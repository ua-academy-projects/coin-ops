{
    "instances": {
        "jump-host": {
            "subnet": "external",
            "has_public_ip": true,
            "instance_size": "small",
            "can_ip_forward": true,
            "role": "jump-host",
            "startup_script": "scripts/nat-init.sh.tpl",
            "clouds": ["gcp", "aws", "azure"]
        },
        "gateway": {
            "subnet": "external",
            "has_public_ip": true,
            "instance_size": "small",
            "can_ip_forward": true,
            "role": "gateway",
            "startup_script": "scripts/gateway-init.sh.tpl",
            "clouds": ["gcp", "aws", "azure"]
        },
        "app-1": {
            "subnet": "external",
            "has_public_ip": true,
            "role": "app-ui",
            "image_profile": "coinops-app-host",
            "instance_size": "micro",
            "disk_size": 30,
            "clouds": ["gcp"]
        },
        "app-2": {
            "subnet": "internal",
            "role": "app-backend",
            "image_profile": "coinops-app-host",
            "instance_size": "small",
            "disk_size": 30,
            "clouds": ["aws"]
        }
    }
}
