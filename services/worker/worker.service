[Unit]
Description="CoinOps History Service (MQ consumer + HTTP API)"
After=multi-user.target
RequiresMountsFor=/home/vagrant/shared_folder/

[Service]
Type=simple
EnvironmentFile=/home/vagrant/shared_folder/worker/worker.env
ExecStart=/home/vagrant/venv/bin/python /home/vagrant/shared_folder/worker/worker.py
User=vagrant
WorkingDirectory=/home/vagrant/shared_folder/worker
Restart=on-failure

[Install]
WantedBy=multi-user.target