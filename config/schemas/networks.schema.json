{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "networks.schema.json",
  "title": "Networks Configuration",
  "description": "Cloud-agnostic VPC networks and subnets configuration",
  "type": "object",
  "required": [
    "networks",
    "subnets"
  ],
  "additionalProperties": false,
  "properties": {
    "networks": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "description": {
            "type": "string"
          }
        }
      }
    },
    "subnets": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "network",
          "cidr"
        ],
        "additionalProperties": false,
        "properties": {
          "network": {
            "type": "string"
          },
          "cidr": {
            "type": "string",
            "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/[0-9]{1,2}$"
          }
        }
      }
    }
  }
}
