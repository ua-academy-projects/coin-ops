{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "general.schema.json",
  "title": "General Configuration",
  "description": "Shared multi-cloud project settings and default values",
  "type": "object",
  "required": [
    "providers",
    "environment",
    "default_os",
    "default_machine_type",
    "default_disk_size_gb",
    "default_disk_type",
    "ssh_user",
    "ssh_port"
  ],
  "additionalProperties": false,
  "properties": {
    "providers": {
      "type": "object",
      "required": [
        "gcp",
        "aws",
        "azure"
      ],
      "additionalProperties": false,
      "properties": {
        "gcp": {
          "type": "object",
          "required": [
            "project_id",
            "region",
            "zone"
          ],
          "additionalProperties": false,
          "properties": {
            "project_id": {
              "type": "string",
              "minLength": 1
            },
            "region": {
              "type": "string",
              "minLength": 1
            },
            "zone": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "aws": {
          "type": "object",
          "required": [
            "region"
          ],
          "additionalProperties": false,
          "properties": {
            "region": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "azure": {
          "type": "object",
          "required": [
            "subscription_id",
            "location",
            "resource_group_name"
          ],
          "additionalProperties": false,
          "properties": {
            "subscription_id": {
              "type": "string",
              "minLength": 1
            },
            "location": {
              "type": "string",
              "minLength": 1
            },
            "resource_group_name": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "environment": {
      "type": "string",
      "enum": [
        "learning",
        "dev",
        "staging",
        "prod"
      ]
    },
    "default_os": {
      "type": "string",
      "enum": [
        "debian-12",
        "debian-11",
        "ubuntu-22"
      ]
    },
    "default_machine_type": {
      "type": "string",
      "enum": [
        "small",
        "medium",
        "large"
      ]
    },
    "default_disk_size_gb": {
      "type": "integer",
      "minimum": 10,
      "maximum": 200
    },
    "default_disk_type": {
      "type": "string",
      "enum": [
        "standard",
        "balanced",
        "ssd"
      ]
    },
    "ssh_user": {
      "type": "string",
      "minLength": 1
    },
    "ssh_port": {
      "type": "integer",
      "minimum": 1024,
      "maximum": 65535
    }
  }
}