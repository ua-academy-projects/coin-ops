{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "firewall.schema.json",
  "title": "Firewall Rules Configuration",
  "description": "Cloud-agnostic firewall and security group rules",
  "type": "object",
  "required": [
    "firewall_rules"
  ],
  "additionalProperties": false,
  "properties": {
    "firewall_rules": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "network",
          "target_tags",
          "description"
        ],
        "additionalProperties": false,
        "properties": {
          "network": {
            "type": "string"
          },
          "protocol": {
            "type": "string",
            "enum": [
              "tcp",
              "udp",
              "icmp",
              "all"
            ]
          },
          "protocols": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "tcp",
                "udp",
                "icmp",
                "all"
              ]
            }
          },
          "ports": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source_ranges": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "source_tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "target_tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}
