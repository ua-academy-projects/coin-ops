{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "vms.schema.json",
  "title": "VMs Configuration",
  "description": "Cloud-agnostic virtual machine instances configuration",
  "type": "object",
  "required": [
    "vms"
  ],
  "additionalProperties": false,
  "properties": {
    "provider": {
      "type": "string",
      "enum": [
        "gcp",
        "aws",
        "azure"
      ],
      "description": "Optional. Pins this VM to a specific cloud. If omitted, the VM is created in the cloud passed via the 'cloud' variable."
    },
    "machine_type": {
      "type": "string",
      "enum": [
        "small",
        "medium",
        "large"
      ]
    },
    "os_image": {
      "type": "string",
      "enum": [
        "debian-12",
        "debian-11",
        "ubuntu-22"
      ]
    },
    "disk_size_gb": {
      "type": "integer",
      "minimum": 10,
      "maximum": 200
    },
    "disk_type": {
      "type": "string",
      "enum": [
        "standard",
        "balanced",
        "ssd"
      ]
    },
    "network": {
      "type": "string"
    },
    "subnet": {
      "type": "string"
    },
    "assign_public_ip": {
      "type": "boolean",
      "default": false
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "labels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}