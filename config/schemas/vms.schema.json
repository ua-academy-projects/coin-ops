{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "vms.schema.json",
  "title": "VMs Configuration",
  "description": "Virtual machine instances configuration",
  "type": "object",
  "required": ["vms"],
  "additionalProperties": false,
  "properties": {
    "vms": {
      "type": "object",
      "description": "Map of VM instances to create",
      "additionalProperties": {
        "type": "object",
        "required": ["network", "subnet", "tags"],
        "additionalProperties": false,
        "properties": {
          "machine_type": {
            "type": "string",
            "description": "Override default machine type",
            "enum": ["e2-micro", "e2-small", "e2-medium"]
          },
          "os_image": {
            "type": "string",
            "description": "Override default OS image"
          },
          "disk_size_gb": {
            "type": "integer",
            "description": "Override default disk size in GB",
            "minimum": 10,
            "maximum": 200
          },
          "disk_type": {
            "type": "string",
            "description": "Override default disk type",
            "enum": ["pd-standard", "pd-balanced", "pd-ssd"]
          },
          "network": {
            "type": "string",
            "description": "VPC network name"
          },
          "subnet": {
            "type": "string",
            "description": "Subnet name"
          },
          "assign_public_ip": {
            "type": "boolean",
            "description": "Whether to assign a public IP",
            "default": false
          },
          "tags": {
            "type": "array",
            "description": "Network tags for firewall rules",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "labels": {
            "type": "object",
            "description": "Labels to apply to the VM",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}