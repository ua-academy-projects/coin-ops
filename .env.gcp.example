# Copy to .env for the GCP VM deployment flow.
# Keep .env local only; it contains secrets and is intentionally ignored by git.

export SSH_KEY_PATH="$HOME/.ssh/gcp_jump"
export ANSIBLE_USER="terraform"

export RABBITMQ_PASSWORD="change-me-rabbitmq-password"
export DB_PASSWORD="change-me-db-password"

export RUNTIME_BACKEND="external"
export IMAGE_TAG="dev-latest"

# The GCP HTTPS Load Balancer terminates TLS. The UI container listens on HTTP
# behind the load balancer.
export APP_DOMAIN="coinops-kazachuk.pp.ua"
export TLS_MODE="off"

# Required when GHCR packages are private.
# Create a GitHub classic PAT with read:packages. If the package is tied to a
# private repository, the token may also need repo access.
export GHCR_USERNAME="your-github-username"
export GHCR_TOKEN="your-github-token"
